{
  "version": 2,
  "routes": [
    {
      "src": "/games/(.*)",
      "dest": "/games/$1"
    }
  ],
  "headers": [
    {
      "source": "/games/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
